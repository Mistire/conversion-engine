# ─── LLM ─────────────────────────────────────────────────────────────────────
# Dev-tier: OpenRouter (Qwen3 / DeepSeek V3.2) — target < $4 for Days 1-4
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=qwen/qwen3-235b-a22b   # or deepseek/deepseek-chat-v3-5

# Eval-tier: Claude Sonnet 4.6 — used ONLY for sealed held-out scoring (Days 5-7)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── OBSERVABILITY ────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── EMAIL (PRIMARY channel) ─────────────────────────────────────────────────
# Sign up: https://resend.com (free tier: 3,000 emails/month, no credit card)
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=outreach@yourdomain.com

# Alternative: MailerSend (https://www.mailersend.com)
MAILERSEND_API_KEY=your_mailersend_api_key_here

# Webhook URL where email replies are POSTed (your public backend URL)
EMAIL_WEBHOOK_URL=https://your-ngrok-or-server-url.com/webhooks/email

# ─── SMS (SECONDARY channel — warm leads only) ────────────────────────────────
# Sign up: https://account.africastalking.com/apps/sandbox (free, no credit card)
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=your_africastalking_api_key_here
AFRICASTALKING_SHORTCODE=your_virtual_shortcode_here

# Webhook URL where inbound SMS are POSTed
SMS_WEBHOOK_URL=https://your-ngrok-or-server-url.com/webhooks/sms

# ─── CRM (HubSpot) ───────────────────────────────────────────────────────────
# Sign up: https://developers.hubspot.com (free developer sandbox)
# Create an app → Private App → generate access token
HUBSPOT_ACCESS_TOKEN=your_hubspot_access_token_here
HUBSPOT_PORTAL_ID=your_portal_id_here

# ─── CALENDAR (Cal.com) ──────────────────────────────────────────────────────
# Self-hosted via Docker (see docker-compose.yml in calcom/)
# Or use Cal.com cloud free tier: https://cal.com
CALCOM_API_KEY=your_calcom_api_key_here
CALCOM_BASE_URL=http://localhost:3000   # or https://api.cal.com/v2 for cloud
CALCOM_EVENT_TYPE_ID=your_event_type_id_here

# ─── SAFETY / ROUTING ────────────────────────────────────────────────────────
# CRITICAL: When set to "true", all outbound routes to STAFF_SINK_EMAIL only
# Default MUST be true (safe). Only set false with explicit program staff approval.
LIVE_MODE=false
STAFF_SINK_EMAIL=staff-sink@10academy.org
STAFF_SINK_SMS=+251900000000

# ─── APP ─────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8080
SECRET_KEY=generate_a_random_secret_key_here
